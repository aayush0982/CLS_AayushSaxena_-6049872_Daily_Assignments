	<bean id="emp7" class="Assignment_7.sprincorebeans.Employee">
		<property name="empname" value="VALE"></property>
		<property name="empid" value="101"></property>
		<property name="empsalary" value="327467.21"></property>
		<property name="empdept" value="SCI"></property>
