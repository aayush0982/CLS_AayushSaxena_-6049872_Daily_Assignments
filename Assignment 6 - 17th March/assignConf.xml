	</bean>
	<bean id="emp8" class="Assignment_7.sprincorebeans.Employee">
		<property name="empname" value="GRENINJA"></property>
		<property name="empid" value="102"></property>
		<property name="empsalary" value="285000.50"></property>
		<property name="empdept" value="IT"></property>
		<property name="empage" value="29"></property>
	</bean>

	<bean id="sbu2" class="Assignment_7.sprincorebeans.Department">
		<property name="sbuID" value="PES-BU"></property>
		<property name="sbuName" value="Product Engineering Services"></property>
		<property name="sbuHead" value="Kiran Rap"></property>
		<property name="employeeList">
			<list>
