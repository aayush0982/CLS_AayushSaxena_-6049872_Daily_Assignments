<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="emp5" class="Assignment_5_and_6.springcorebeans.Employee5">
		<property name="empname" value="VALE"></property>
		<property name="empid" value="101"></property>
		<property name="empsalary" value="327467.21"></property>
		<property name="empdept" value="SCI"></property>
		<property name="empage" value="34"></property>
	</bean>
	<bean id="emp6" class="Assignment_5_and_6.springcorebeans.Employee6">
		<property name="empname" value="VALE"></property>
		<property name="empid" value="101"></property>
		<property name="empsalary" value="327467.21"></property>
		<property name="empdept" ref="sbu"></property>
		<property name="empage" value="34"></property>
	</bean>

	<bean id="sbu" class="Assignment_5_and_6.springcorebeans.Department">
		<property name="sbuID" value="PES-BU"></property>
